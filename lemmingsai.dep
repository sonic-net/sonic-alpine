#DPKG FRK
$(LEMMINGSAI)_CACHE_MODE  := GIT_CONTENT_SHA

SPATH       := $($(LEMMINGSAI)_SRC_PATH)
DEP_FILES   := $(SONIC_COMMON_FILES_LIST) platform/alpinevs/lemmingsai.mk platform/alpinevs/lemmingsai.dep
DEP_FILES   += $(SONIC_COMMON_BASE_FILES_LIST)
DEP_FILES   += $(shell git ls-files $(SPATH))
SMDEP_PATHS := $(SPATH) $(SPATH)/lemming
$(foreach path, $(SMDEP_PATHS), $(eval $(path) :=$(filter-out $(SMDEP_PATHS),$(addprefix $(path)/, \
                                 $(shell cd $(path)  && git ls-files | grep -v " ")))))

$(LEMMINGSAI)_CACHE_MODE  := GIT_CONTENT_SHA
$(LEMMINGSAI)_DEP_FLAGS   := $(SONIC_COMMON_FLAGS_LIST)
$(LEMMINGSAI)_DEP_FILES   := $(DEP_FILES)
$(LEMMINGSAI)_SMDEP_FILES := $(foreach path, $(SMDEP_PATHS), $($(path)))
$(LEMMINGSAI)_SMDEP_PATHS := $(SMDEP_PATHS)
