SPATH := $($(SONIC_PLATFORM_API_PY3)_SRC_PATH)
SLINKS := $(shell find $(SPATH) -type l -exec echo {} \; | grep -Ev ' ')
DEP_FILES := $(SONIC_COMMON_FILES_LIST) $(PLATFORM_PATH)/platform-alpinevs.mk $(PLATFORM_PATH)/platform-alpinevs.dep
DEP_FILES += $(SONIC_COMMON_BASE_FILES_LIST)
SMDEP_FILES := $(addprefix $(SPATH)/,$(shell cd $(SPATH) && git ls-files))

$(SONIC_PLATFORM_API_PY3)_CACHE_MODE := GIT_CONTENT_SHA
$(SONIC_PLATFORM_API_PY3)_DEP_FLAGS := $(SONIC_COMMON_FLAGS_LIST)
$(SONIC_PLATFORM_API_PY3)_DEP_FILES := $(DEP_FILES)
$(SONIC_PLATFORM_API_PY3)_SMDEP_FILES := $(filter-out $(SLINKS),$(SMDEP_FILES))
$(SONIC_PLATFORM_API_PY3)_SMDEP_PATHS := $(SPATH)
